# Copy to .env for local dev (or set these in the Railway service variables).

# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-insecure-change-me
DEBUG=true

# Comma-separated. On Railway set to your app domain, e.g. live-chat-xxxx.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins, e.g. https://live-chat-xxxx.up.railway.app
CSRF_TRUSTED_ORIGINS=

# Provided automatically by the Railway Postgres service. Local default is SQLite.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Provided automatically by the Railway Redis service. Local default is localhost.
REDIS_URL=redis://127.0.0.1:6379/0
